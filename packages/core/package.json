{
  "name": "@mcdays94/cf-images-core",
  "version": "0.0.1",
  "description": "Core TypeScript logic for the CF Images tools — upload, dedupe, signed URLs, compression, metadata. No editor or platform assumptions. Unofficial.",
  "author": "Miguel Caetano Dias <amtccdias@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcdays94/cf-images-tools",
    "directory": "packages/core"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-images",
    "image-upload",
    "cdn",
    "image-hosting"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
