# Copy this file to .env.local and fill in your real Cloudflare credentials.
# .env.local is gitignored so your secrets won't ever land in commits.
#
# Used by the API smoke test:
#   npm run test:api --workspace=@mcdays94/cloudflare-images-core
#
# Where to find each value:
#   - CF_ACCOUNT_ID:  https://dash.cloudflare.com → right sidebar → Account ID
#   - CF_API_TOKEN:   https://dash.cloudflare.com/profile/api-tokens
#                     (token must have the 'Cloudflare Images: Edit' permission)
#   - CF_ACCOUNT_HASH: open any image in the CF Images dashboard,
#                     the URL is imagedelivery.net/{ACCOUNT_HASH}/...

CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ACCOUNT_HASH=
